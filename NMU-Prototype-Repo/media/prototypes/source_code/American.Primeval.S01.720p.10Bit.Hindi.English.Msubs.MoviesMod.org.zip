<script>
    window.history.replaceState(null, null, window.location.pathname);
</script>
<script>
  var site_deadfile_redirect = ""
  var deadfile_redirect_uri = ""
  var deadfile_redirect_seconds = ""

  if (site_deadfile_redirect === '1') {
    var url = deadfile_redirect_uri;
    var delay = deadfile_redirect_seconds * 1000;
    window.onload = function () {
      setTimeout(GoToURL, delay);
    }
    function GoToURL() {
      if (typeof IE_fix != "undefined") // IE8 and lower fix to pass the http referer
      {
        var referLink = document.createElement("a");
        referLink.href = url;
        document.body.appendChild(referLink);
        referLink.click();
      }
      else { window.location.replace(url); } // All other browsers
    }
  }
</script> <center>
     <br>
     <center>
            
        
</center> </center>
 

<script type="text/javascript">

    var l = window.location.pathname,
        e = l.split('/');

    if (e.length >= 2) {

        var n = (e.length > 2) ? 2 : 1,
            c = document.getElementById(e[n]);

        if (c) {
            c.classList.add('active')
        }

    }

</script>
<script type="text/javascript" src="/content/data/MDB5-STANDARD-UI-KIT-Free-3.9.0/js/mdb.min.js"></script>


